    "   \"source\": [\n",
    "\t\"# Anomaly Detection for Energy Analytics - NSP Dataset\\n\",\n",
    "\t\"\\n\",\n",
    "\t\"This notebook contains approaches to detect anomalies in the NSP electricity dataset: statistical, ML-based, and forecast-residual methods. Results will be exported to `output/anomaly_results.csv` for downstream dashboards.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "\t\"## Setup and Imports\\n\",\n",
    "\t\"\\n\",\n",
    "\t\"Imports, path setup, and helper functions.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "\t\"import pandas as pd\\n\",\n",
    "\t\"import numpy as np\\n\",\n",
    "\t\"import matplotlib.pyplot as plt\\n\",\n",
    "\t\"import seaborn as sns\\n\",\n",
    "\t\"from pathlib import Path\\n\",\n",
    "\t\"from sklearn.ensemble import IsolationForest\\n\",\n",
    "\t\"from scipy import stats\\n\",\n",
    "\t\"\\n\",\n",
    "\t\"# Define directories relative to this file\\n\",\n",
    "\t\"ROOT_DIR = Path.cwd().parent\\n\",\n",
    "\t\"DATA_DIR = ROOT_DIR / 'data'\\n\",\n",
    "\t\"OUTPUT_DIR = ROOT_DIR / 'output'\\n\",\n",
    "\t\"OUTPUT_DIR.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "\t\"\\n\",\n",
    "\t\"def save_and_show_plot(fig, filename):\\n\",\n",
    "\t\"    output_path = OUTPUT_DIR / filename\\n\",\n",
    "\t\"    fig.savefig(output_path, dpi=300, bbox_inches='tight')\\n\",\n",
    "\t\"    print(f\\\"Plot saved: {output_path}\\\")\\n\",\n",
    "\t\"    plt.show()\\n\",\n",
    "\t\"\\n\",\n",
    "\t\"# Load data\\n\",\n",
    "\t\"df = pd.read_csv(DATA_DIR / 'nsp_electricity_dataset.csv', parse_dates=['timestamp'], low_memory=False)\\n\",\n",
    "\t\"print(f\\\"Dataset shape: {df.shape}\\\")\\n\",\n",
    "\t\"print(df.info())\\n\",\n",
    "\t\"print(df.head())\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "\t\"## Data Loading and Preparation\\n\",\n",
    "\t\"\\n\",\n",
    "\t\"Load full NSP dataset, inspect structure, and check for an existing `anomaly_flag` column.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "\t\"# Check for anomaly_flag column\\n\",\n",
    "\t\"print(f\\\"Columns: {df.columns.tolist()}\\\")\\n\",\n",
